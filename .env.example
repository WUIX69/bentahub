# BentaHub Environment Variables

# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/bentahub"

# JWT Configuration
JWT_SECRET="your-secret-key-change-in-production"

# Email Configuration (Leave blank for automatic Mailpit or Ethereal fallback)
EMAIL_SERVICE=""
EMAIL_USER=""
EMAIL_PASSWORD=""
EMAIL_FROM="noreply@bentahub.local"
EMAIL_HOST="localhost"
EMAIL_PORT="1025"

# App Configuration
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: Third-party services
# STRIPE_SECRET_KEY=""
# STRIPE_PUBLIC_KEY=""
# GCASH_API_KEY=""
